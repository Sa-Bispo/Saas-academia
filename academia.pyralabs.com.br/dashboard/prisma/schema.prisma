generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(uuid()) @db.Uuid
  email       String   @unique @db.VarChar(255)
  nome        String   @db.VarChar(120)
  dataCriacao DateTime @default(now()) @map("data_criacao")

  tenants Tenant[]

  @@map("users")
}

model Tenant {
  id                    String   @id @default(uuid()) @db.Uuid
  nome                  String   @db.VarChar(120)
  plano                 String   @default("pro") @db.VarChar(20)
  promptIa              String?
  whatsappAdmin         String?  @db.VarChar(30)
  dataCriacao           DateTime @default(now()) @map("data_criacao")
  userId                String   @map("user_id") @db.Uuid
  evolutionInstanceName String?  @unique @db.VarChar(120)
  evolutionApiKey       String?
  whatsappStatus        String   @default("DISCONNECTED") @db.VarChar(20)

  // Construtor de Persona (campos estruturados)
  botName          String? @db.VarChar(80)
  companyName      String? @db.VarChar(120)
  toneOfVoice      String? @db.VarChar(40)
  strictRules      String? @db.Text
  botObjective     String? @db.VarChar(40)
  operationContext String? @db.Text // horários, área, pagamentos, etc.

  // Configuração de sub-nicho (adega, pizzaria, etc.)
  configNicho Json @default("{}") @map("config_nicho")

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  stockItems         StockItem[]
  categoriasCardapio CategoriaCardapio[]
  combos             Combo[]
  pizzaTamanhos      PizzaTamanho[]
  pizzaBordas        PizzaBorda[]
  bebidas            Bebida[]
  stockMovements     StockMovement[]
  customers          Customer[]
  orders             Order[]
  motoboys           Motoboy[]
  zonasEntrega       ZonaEntrega[]
  entregas           Entrega[]
  produtos           Produto[]
  subscription       Subscription?
  appointments       Appointment[]
  chamados           Chamado[]
  alunos             Aluno[]
  planosAcademia     PlanoAcademia[]
  matriculasAlunos   MatriculaAluno[]
  cobrancasAlunos    CobrancaAluno[]
  frequenciasAlunos  FrequenciaAluno[]
  fichasParq         FichaParq[]
  perguntasParq      ParqPergunta[]
  botConfusionEvents BotConfusionEvent[]
  funcionarios       Funcionario[]
  codigosPagamento   CodigoPagamento[]
  tenantModulos      TenantModulo[]

  @@index([userId])
  @@map("tenants")
}

// ─── Billing ──────────────────────────────────────────────────────────────────

enum Niche {
  DELIVERY
  CLINICA
  EMPRESA
  ACADEMIA
}

enum SubscriptionStatus {
  PENDING // aguardando primeiro pagamento
  ACTIVE // pago e ativo
  PAST_DUE // falha no pagamento (carência de 3 dias)
  CANCELLED // cancelado pelo usuário
  EXPIRED // carência encerrada, acesso bloqueado
}

model Plan {
  id         String @id @default(uuid()) @db.Uuid
  code       String @unique @db.VarChar(60) // ex: "delivery_basico"
  niche      Niche
  name       String @db.VarChar(80)
  priceCents Int    @map("price_cents") // 4990 = R$49,90

  // Limites quantitativos (-1 = ilimitado)
  maxMessagesMonth     Int @default(-1) @map("max_messages_month")
  maxProducts          Int @default(-1) @map("max_products")
  maxAppointmentsMonth Int @default(-1) @map("max_appointments_month")
  maxProfessionals     Int @default(-1) @map("max_professionals")
  maxContactsMonth     Int @default(-1) @map("max_contacts_month")
  maxDocuments         Int @default(-1) @map("max_documents")

  // Feature flags
  menuReaderEnabled   Boolean @default(false) @map("menu_reader_enabled")
  reportsEnabled      Boolean @default(false) @map("reports_enabled")
  ragEnabled          Boolean @default(false) @map("rag_enabled")
  humanHandoffEnabled Boolean @default(false) @map("human_handoff_enabled")
  remindersEnabled    Boolean @default(false) @map("reminders_enabled")
  cancellationEnabled Boolean @default(false) @map("cancellation_enabled")
  multiProfessional   Boolean @default(false) @map("multi_professional")

  subscriptions Subscription[]
  createdAt     DateTime       @default(now()) @map("created_at")

  @@map("plans")
}

model Subscription {
  id       String             @id @default(uuid()) @db.Uuid
  tenantId String             @unique @map("tenant_id") @db.Uuid
  planId   String             @map("plan_id") @db.Uuid
  status   SubscriptionStatus @default(PENDING)

  currentPeriodStart DateTime @map("current_period_start")
  currentPeriodEnd   DateTime @map("current_period_end")

  mpPaymentId     String? @map("mp_payment_id") @db.VarChar(80)
  mpPreapprovalId String? @map("mp_preapproval_id") @db.VarChar(80)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan   Plan   @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

model UsageRecord {
  id           String @id @default(uuid()) @db.Uuid
  tenantId     String @map("tenant_id") @db.Uuid
  period       String @db.VarChar(7) // "2026-04"
  messages     Int    @default(0)
  appointments Int    @default(0)
  tickets      Int    @default(0)

  @@unique([tenantId, period])
  @@map("usage_records")
}

model StockItem {
  id            String   @id @default(uuid()) @db.Uuid
  nome          String   @db.VarChar(160)
  descricao     String?  @db.Text
  variacao      String?  @db.VarChar(120)
  preco         Decimal  @db.Decimal(10, 2)
  tem_variacoes Boolean  @default(false)
  quantidade    Int      @default(0)
  ativo         Boolean  @default(true)
  tenantId      String   @map("tenant_id") @db.Uuid
  dataCriacao   DateTime @default(now()) @map("data_criacao")

  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  movements  StockMovement[]
  variacoes  ItemVariacao[]
  adicionais ItemAdicional[]

  @@index([tenantId])
  @@map("stock_items")
}

model ItemVariacao {
  id         String   @id @default(uuid()) @db.Uuid
  item_id    String   @db.Uuid
  nome       String   @db.VarChar(120)
  sigla      String?  @db.VarChar(12)
  preco      Float
  ordem      Int      @default(0)
  created_at DateTime @default(now())

  item StockItem @relation(fields: [item_id], references: [id], onDelete: Cascade)

  @@index([item_id])
  @@map("item_variacoes")
}

model ItemAdicional {
  id          String   @id @default(uuid()) @db.Uuid
  item_id     String   @db.Uuid
  nome        String   @db.VarChar(120)
  preco_extra Float    @default(0)
  ativo       Boolean  @default(true)
  created_at  DateTime @default(now())

  item StockItem @relation(fields: [item_id], references: [id], onDelete: Cascade)

  @@index([item_id])
  @@map("item_adicionais")
}

model CategoriaCardapio {
  id         String   @id @default(uuid()) @db.Uuid
  tenant_id  String   @db.Uuid
  nome       String   @db.VarChar(120)
  ordem      Int      @default(0)
  created_at DateTime @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@map("categorias_cardapio")
}

model Chamado {
  id         String   @id @default(uuid()) @db.Uuid
  tenant_id  String   @db.Uuid
  tipo       String   @db.VarChar(30)
  titulo     String   @db.VarChar(160)
  status     String   @default("ABERTO") @db.VarChar(20)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant    Tenant            @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  mensagens MensagemChamado[]

  @@index([tenant_id])
  @@index([status])
  @@map("chamados")
}

model MensagemChamado {
  id         String   @id @default(uuid()) @db.Uuid
  chamado_id String   @db.Uuid
  autor      String   @db.VarChar(20)
  texto      String?  @db.Text
  imagem_url String?  @db.Text
  lida       Boolean  @default(false)
  created_at DateTime @default(now())

  chamado Chamado @relation(fields: [chamado_id], references: [id], onDelete: Cascade)

  @@index([chamado_id])
  @@index([autor, lida])
  @@map("mensagens_chamado")
}

model Combo {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  nome      String   @db.VarChar(160)
  descricao String?  @db.Text
  preco     Float
  ativo     Boolean  @default(true)
  itens     String[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("combos")
}

model PizzaTamanho {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  sigla            String   @db.VarChar(6)
  nome             String   @db.VarChar(40)
  fatias           Int
  modificadorPreco Float    @default(0) @map("modificador_preco")
  ordem            Int      @default(0)
  createdAt        DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, sigla])
  @@index([tenantId])
  @@map("pizza_tamanhos")
}

model PizzaBorda {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  nome       String   @db.VarChar(120)
  precoExtra Float    @default(0) @map("preco_extra")
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, nome])
  @@index([tenantId])
  @@map("pizza_bordas")
}

model Bebida {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  nome      String   @db.VarChar(160)
  preco     Float
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("bebidas")
}

model StockMovement {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  productId   String   @map("product_id") @db.Uuid
  type        String   @db.VarChar(40) // "saida_automatica" | "entrada_manual" | "saida_manual"
  quantity    Int // positivo = entrada, negativo = saída
  description String   @db.VarChar(255)
  orderId     String?  @map("order_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  tenant  Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product StockItem @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([productId])
  @@map("stock_movements")
}

model Produto {
  id              String   @id @default(uuid()) @db.Uuid
  nome            String   @db.VarChar(160)
  categoria       String   @db.VarChar(120)
  precoBase       Decimal  @map("preco_base") @db.Decimal(10, 2)
  ativo           Boolean  @default(true)
  classeNegocio   String   @map("classe_negocio") @db.VarChar(50)
  configNicho     Json     @default("{}") @map("config_nicho")
  regrasIa        String?  @map("regras_ia") @db.Text
  tenantId        String   @map("tenant_id") @db.Uuid
  dataCriacao     DateTime @default(now()) @map("data_criacao")
  dataAtualizacao DateTime @updatedAt @map("data_atualizacao")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([classeNegocio])
  @@map("produtos")
}

model Customer {
  id       String @id @default(uuid()) @db.Uuid
  telefone String @db.VarChar(30)
  nome     String @db.VarChar(120)
  endereco String @db.VarChar(255)
  tenantId String @map("tenant_id") @db.Uuid

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([tenantId])
  @@index([tenantId, telefone])
  @@map("customers")
}

model Order {
  id              String      @id @default(uuid()) @db.Uuid
  status          OrderStatus @default(NOVO)
  total           Decimal     @db.Decimal(10, 2)
  forma_pagamento String      @db.VarChar(40)
  tenantId        String      @map("tenant_id") @db.Uuid
  customerId      String      @map("customer_id") @db.Uuid
  data_criacao    DateTime    @default(now()) @map("data_criacao")

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items    OrderItem[]
  entrega  Entrega?

  @@index([tenantId])
  @@index([customerId])
  @@index([status])
  @@map("orders")
}

model Motoboy {
  id           String   @id @default(uuid()) @db.Uuid
  tenant_id    String   @db.Uuid
  nome         String
  telefone     String?
  ativo        Boolean  @default(true)
  fixo_diario  Float    @default(0)
  turno_inicio String?
  turno_fim    String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  entregas Entrega[]

  @@index([tenant_id])
  @@map("motoboys")
}

model ZonaEntrega {
  id         String   @id @default(uuid()) @db.Uuid
  tenant_id  String   @db.Uuid
  nome       String
  cor        String   @default("#1D9E75")
  taxa       Float
  bairros    String[]
  ordem      Int      @default(0)
  created_at DateTime @default(now())

  tenant   Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  entregas Entrega[]

  @@index([tenant_id])
  @@map("zonas_entrega")
}

model Entrega {
  id            String    @id @default(uuid()) @db.Uuid
  tenant_id     String    @db.Uuid
  order_id      String    @unique @db.Uuid
  motoboy_id    String    @db.Uuid
  zona_id       String?   @db.Uuid
  taxa          Float
  fixo_incluido Boolean   @default(false)
  status        String    @default("PENDENTE")
  pago_em       DateTime?
  created_at    DateTime  @default(now())

  tenant  Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  order   Order        @relation(fields: [order_id], references: [id], onDelete: Cascade)
  motoboy Motoboy      @relation(fields: [motoboy_id], references: [id], onDelete: Cascade)
  zona    ZonaEntrega? @relation(fields: [zona_id], references: [id], onDelete: SetNull)

  @@index([tenant_id])
  @@index([motoboy_id])
  @@index([zona_id])
  @@map("entregas")
}

model OrderItem {
  id             String  @id @default(uuid()) @db.Uuid
  orderId        String  @map("order_id") @db.Uuid
  nome_produto   String  @db.VarChar(160)
  quantidade     Int     @default(1)
  preco_unitario Decimal @db.Decimal(10, 2)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_items")
}

enum OrderStatus {
  NOVO
  PREPARANDO
  ENVIADO
  CONCLUIDO
  CANCELADO
}

// ─── Agenda ───────────────────────────────────────────────────────────────────

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

model Appointment {
  id             String            @id @default(uuid()) @db.Uuid
  tenantId       String            @map("tenant_id") @db.Uuid
  clientName     String            @map("client_name") @db.VarChar(120)
  clientPhone    String            @map("client_phone") @db.VarChar(30)
  type           String            @db.VarChar(60)
  professional   String            @db.VarChar(120)
  scheduledAt    DateTime          @map("scheduled_at")
  status         AppointmentStatus @default(PENDING)
  confirmedByBot Boolean           @default(false) @map("confirmed_by_bot")
  notes          String?           @db.Text
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, scheduledAt])
  @@map("appointments")
}

// ─── Academia ─────────────────────────────────────────────────────────────────

enum AlunoStatus {
  ATIVO
  INADIMPLENTE
  INATIVO
  SUSPENSO
  SEM_MATRICULA
}

enum MatriculaStatus {
  ATIVA
  VENCIDA
  CANCELADA
}

enum CobrancaStatus {
  PENDENTE
  AGUARDANDO_VALIDACAO
  PAGO
  VENCIDO
  CANCELADA
}

enum FormaPagamento {
  DINHEIRO
  PIX
}

enum ParqItemTipo {
  PERGUNTA
  TEXTO
}

enum Periodicidade {
  MENSAL
  TRIMESTRAL
  SEMESTRAL
  ANUAL
}

model Aluno {
  id                     String      @id @default(uuid()) @db.Uuid
  tenantId               String      @map("tenant_id") @db.Uuid
  nome                   String      @db.VarChar(120)
  telefone               String      @db.VarChar(30)
  email                  String?     @db.VarChar(255)
  cpf                    String?     @db.VarChar(14)
  dataNascimento         DateTime?   @map("data_nascimento")
  observacoes            String?     @db.Text
  status                 AlunoStatus @default(ATIVO)
  precisaLiberacaoMedica Boolean     @default(false) @map("precisa_liberacao_medica")
  optoutCobranca         Boolean     @default(false) @map("optout_cobranca")
  optoutCobrancaAt       DateTime?   @map("optout_cobranca_at")
  createdAt              DateTime    @default(now()) @map("created_at")
  updatedAt              DateTime    @updatedAt @map("updated_at")

  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  matriculas  MatriculaAluno[]
  cobrancas   CobrancaAluno[]
  frequencias FrequenciaAluno[]
  fichasParq  FichaParq[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("alunos")
}

model PlanoAcademia {
  id                 String        @id @default(uuid()) @db.Uuid
  tenantId           String        @map("tenant_id") @db.Uuid
  nome               String        @db.VarChar(120)
  descricao          String?       @db.Text
  valorCents         Int           @map("valor_cents")
  valorCentsDinheiro Int?          @map("valor_cents_dinheiro")
  valorCentsPix      Int?          @map("valor_cents_pix")
  periodicidade      Periodicidade @default(MENSAL)
  ativo              Boolean       @default(true)
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  matriculas MatriculaAluno[]

  @@index([tenantId])
  @@map("planos_academia")
}

model MatriculaAluno {
  id             String          @id @default(uuid()) @db.Uuid
  alunoId        String          @map("aluno_id") @db.Uuid
  planoId        String          @map("plano_id") @db.Uuid
  tenantId       String          @map("tenant_id") @db.Uuid
  dataInicio     DateTime        @map("data_inicio")
  dataVencimento DateTime        @map("data_vencimento")
  status         MatriculaStatus @default(ATIVA)
  observacoes    String?         @db.Text
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  aluno     Aluno           @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  plano     PlanoAcademia   @relation(fields: [planoId], references: [id], onDelete: Restrict)
  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cobrancas CobrancaAluno[]

  @@index([alunoId])
  @@index([tenantId])
  @@index([tenantId, dataVencimento])
  @@map("matriculas_alunos")
}

model FrequenciaAluno {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  alunoId     String   @map("aluno_id") @db.Uuid
  data        DateTime @db.Date
  horaEntrada String?  @map("hora_entrada") @db.VarChar(5) // "07:30"
  horaSaida   String?  @map("hora_saida") @db.VarChar(5)
  observacoes String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  aluno  Aluno  @relation(fields: [alunoId], references: [id], onDelete: Cascade)

  @@unique([alunoId, data])
  @@index([tenantId])
  @@index([alunoId])
  @@index([tenantId, data])
  @@map("frequencia_alunos")
}

model CobrancaAluno {
  id                         String          @id @default(uuid()) @db.Uuid
  tenantId                   String          @map("tenant_id") @db.Uuid
  alunoId                    String          @map("aluno_id") @db.Uuid
  matriculaId                String?         @map("matricula_id") @db.Uuid
  valorCents                 Int             @map("valor_cents")
  dataVencimento             DateTime        @map("data_vencimento")
  dataPagamento              DateTime?       @map("data_pagamento")
  status                     CobrancaStatus  @default(PENDENTE)
  descricao                  String?         @db.VarChar(255)
  pixChave                   String?         @map("pix_chave") @db.VarChar(120)
  observacoes                String?         @db.Text
  enviadaWhatsapp            Boolean         @default(false) @map("enviada_whatsapp")
  comprovanteUrl             String?         @map("comprovante_url") @db.Text
  comprovanteEnviadoEm       DateTime?       @map("comprovante_enviado_em")
  formaPagamento             FormaPagamento? @map("forma_pagamento")
  confirmadoPorFuncionarioId String?         @map("confirmado_por_funcionario_id") @db.Uuid
  createdAt                  DateTime        @default(now()) @map("created_at")
  updatedAt                  DateTime        @updatedAt @map("updated_at")

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  aluno            Aluno             @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  matricula        MatriculaAluno?   @relation(fields: [matriculaId], references: [id], onDelete: SetNull)
  codigosPagamento CodigoPagamento[]

  @@index([tenantId])
  @@index([alunoId])
  @@index([tenantId, status])
  @@index([tenantId, dataVencimento])
  @@map("cobrancas_alunos")
}

// ─── Bot Feedback System ──────────────────────────────────────────────────────

model BotConfusionEvent {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String?   @map("tenant_id") @db.Uuid
  nicho         String    @db.VarChar(50)
  phone         String?   @db.VarChar(50)
  messagesJson  Json      @default("[]") @map("messages_json")
  textoProblema String    @map("texto_problema") @db.Text
  status        String    @default("pendente") @db.VarChar(20)
  createdAt     DateTime  @default(now()) @map("created_at")
  resolvedAt    DateTime? @map("resolved_at")

  tenant          Tenant?             @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  learnedPatterns BotLearnedPattern[]

  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@index([tenantId])
  @@map("bot_confusion_events")
}

model BotLearnedPattern {
  id         String   @id @default(uuid()) @db.Uuid
  nicho      String   @db.VarChar(50)
  frase      String   @db.Text
  intentAlvo String   @map("intent_alvo") @db.VarChar(50)
  eventoId   String?  @map("evento_id") @db.Uuid
  ativo      Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")

  evento BotConfusionEvent? @relation(fields: [eventoId], references: [id], onDelete: SetNull)

  @@index([nicho, ativo])
  @@index([createdAt(sort: Desc)])
  @@map("bot_learned_patterns")
}

// ─── PAR-Q ────────────────────────────────────────────────────────────────────

model ParqPergunta {
  id        Int          @id @default(autoincrement())
  tenantId  String?      @map("tenant_id") @db.Uuid
  ordem     Int
  texto     String       @db.Text
  tipo      ParqItemTipo @default(PERGUNTA)
  ativo     Boolean      @default(true)
  createdAt DateTime     @default(now()) @map("created_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("parq_perguntas")
}

model FichaParq {
  id                     String   @id @default(uuid()) @db.Uuid
  tenantId               String   @map("tenant_id") @db.Uuid
  alunoId                String   @map("aluno_id") @db.Uuid
  respostas              Json     @db.JsonB
  precisaLiberacaoMedica Boolean  @default(false) @map("precisa_liberacao_medica")
  assinaturaUrl          String?  @map("assinatura_url") @db.Text
  assinaturaBase64       String?  @map("assinatura_base64") @db.Text
  termoHash              String   @map("termo_hash") @db.VarChar(64)
  assinanteNome          String   @map("assinante_nome") @db.VarChar(120)
  assinanteCpf           String   @map("assinante_cpf") @db.VarChar(14)
  ip                     String?  @db.VarChar(50)
  userAgent              String?  @map("user_agent") @db.Text
  consentimentoLgpd      Boolean  @default(false) @map("consentimento_lgpd")
  arquivado              Boolean  @default(false)
  assinadoEm             DateTime @default(now()) @map("assinado_em")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  aluno  Aluno  @relation(fields: [alunoId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([alunoId])
  @@map("fichas_parq")
}

// ─── Funcionários e Códigos de Pagamento ─────────────────────────────────────

model Funcionario {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  nome      String   @db.VarChar(120)
  telefone  String   @db.VarChar(30)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  codigosUsados CodigoPagamento[]

  @@index([tenantId])
  @@index([tenantId, telefone])
  @@map("funcionarios")
}

model CodigoPagamento {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  cobrancaId    String    @map("cobranca_id") @db.Uuid
  codigo        String    @unique @db.VarChar(10)
  expiresAt     DateTime  @map("expires_at")
  usadoEm       DateTime? @map("usado_em")
  funcionarioId String?   @map("funcionario_id") @db.Uuid

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cobranca    CobrancaAluno @relation(fields: [cobrancaId], references: [id], onDelete: Cascade)
  funcionario Funcionario?  @relation(fields: [funcionarioId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([cobrancaId])
  @@map("codigos_pagamento")
}

// ─── Módulos por tenant ───────────────────────────────────────────────────────

model Modulo {
  id        String  @id @default(uuid()) @db.Uuid
  chave     String  @unique @db.VarChar(40)
  nome      String  @db.VarChar(80)
  descricao String? @db.Text
  ordem     Int     @default(0)

  tenantModulos TenantModulo[]

  @@map("modulos")
}

model TenantModulo {
  tenantId String  @map("tenant_id") @db.Uuid
  moduloId String  @map("modulo_id") @db.Uuid
  ativo    Boolean @default(false)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  modulo Modulo @relation(fields: [moduloId], references: [id], onDelete: Cascade)

  @@id([tenantId, moduloId])
  @@map("tenant_modulos")
}

// ─── Waitlist ─────────────────────────────────────────────────────────────────

model WaitlistEntry {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @db.VarChar(255)
  niche     String   @db.VarChar(60)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email, niche])
  @@map("waitlist_entries")
}
