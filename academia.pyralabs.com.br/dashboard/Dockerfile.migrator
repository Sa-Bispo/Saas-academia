FROM node:20-alpine

WORKDIR /app

# Instala deps completas (precisa do prisma CLI que está em devDependencies)
COPY package*.json ./
RUN npm ci --legacy-peer-deps

# Schema, migrations e config do Prisma
COPY prisma ./prisma
COPY prisma.config.ts ./

# prisma db push sincroniza o schema com o banco (compatível com db push workflow)
CMD ["npx", "prisma", "db", "push"]
