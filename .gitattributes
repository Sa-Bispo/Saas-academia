# Normaliza todos os arquivos de texto para LF no repositório
* text=auto eol=lf

# Binários — nunca normalizar
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.mp4 binary
*.mp3 binary
*.webp binary

# Scripts Windows que precisam de CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
